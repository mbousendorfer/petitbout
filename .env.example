# Mode admin (édition du catalogue d'aliments) — facultatif.
# Renseigne les deux hashes pour activer le mode ; vide = désactivé.
# Génère-les avec :
#   node -e "crypto.subtle.digest('SHA-256',new TextEncoder().encode(process.argv[1])).then(b=>console.log([...new Uint8Array(b)].map(x=>x.toString(16).padStart(2,'0')).join('')))" "mon-secret"
# Accès : ouvre /?admin=<secret> une fois, puis saisis le PIN.
VITE_ADMIN_SECRET_HASH=
VITE_ADMIN_PIN_HASH=
